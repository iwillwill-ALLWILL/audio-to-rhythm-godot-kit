{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/audio-to-rhythm-godot-kit/chart.schema.json",
  "title": "RhythmKit Chart v1 - 3-key ASD layout",
  "type": "object",
  "required": ["schema", "song_id", "title", "audio", "duration", "bpm", "difficulty", "lanes", "notes"],
  "properties": {
    "schema": {"const": "com.rhythmkit.chart.v1"},
    "generator_version": {"type": "string"},
    "song_id": {"type": "string"},
    "title": {"type": "string"},
    "artist": {"type": "string"},
    "audio": {"type": "string"},
    "duration": {"type": "number", "minimum": 0},
    "bpm": {"type": "number", "minimum": 1},
    "offset": {"type": "number"},
    "theme": {"type": "string"},
    "difficulty": {
      "type": "object",
      "required": ["name", "rating", "lanes", "note_speed", "perfect_window", "good_window"],
      "properties": {
        "name": {"type": "string"},
        "rating": {"type": "integer"},
        "lanes": {"const": 3},
        "notes_per_30s": {"type": "integer", "minimum": 1},
        "min_gap": {"type": "number", "minimum": 0},
        "note_speed": {"type": "number", "minimum": 1},
        "perfect_window": {"type": "number", "minimum": 0},
        "good_window": {"type": "number", "minimum": 0},
        "allow_doubles": {"type": "boolean"},
        "allow_holds": {"type": "boolean"},
        "dynamic_density": {"type": "number", "minimum": 0, "maximum": 1},
        "section_seconds": {"type": "number", "minimum": 0.5},
        "double_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "hold_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "hold_min": {"type": "number", "minimum": 0},
        "hold_max": {"type": "number", "minimum": 0}
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "name", "default_key"],
        "properties": {
          "id": {"type": "integer", "enum": [0, 1, 2]},
          "name": {"type": "string"},
          "default_key": {"type": "string", "enum": ["A", "S", "D"]}
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "time", "lane", "type"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "time": {"type": "number", "minimum": 0},
          "lane": {"type": "integer", "enum": [0, 1, 2]},
          "type": {"enum": ["tap", "hold"]},
          "duration": {"type": "number", "minimum": 0},
          "source": {"type": "string"},
          "confidence": {"type": "number"},
          "centroid_hz": {"type": "number"},
          "pitch": {"type": ["number", "null"]}
        },
        "allOf": [
          {
            "if": {"properties": {"type": {"const": "hold"}}},
            "then": {"required": ["duration"], "properties": {"duration": {"minimum": 0.05}}}
          }
        ]
      }
    }
  }
}
